# Copy to `.env` and replace all `change-me-*` values before `docker compose up`.
# Moodle admin password must satisfy the site password policy (length + character classes).

# PostgreSQL (Moodle DB)
POSTGRES_DB=moodle
POSTGRES_USER=moodle
POSTGRES_PASSWORD=change-me-db

# Moodle DB connection (entrypoint → CLI install / config.php)
MOODLE_DB_HOST=postgres
MOODLE_DB_PORT=5432
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=change-me-db

# Moodle initial admin + site metadata
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=ChangeMe_Admin1
MOODLE_ADMIN_EMAIL=admin@example.com
MOODLE_SITE_FULLNAME=Neuro Moodle
MOODLE_SITE_SHORTNAME=neuro

# Public URL browsers use (must match how you open Moodle)
MOODLE_BASE_URL=http://localhost:8080
MOODLE_TOKEN=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=course_content

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
# Seconds for each Ollama HTTP call (chat/embed); raise if synthetic course times out on first model load.
OLLAMA_HTTP_TIMEOUT_S=3600

# Neuro ML API (FastAPI) — optional; comma-separated CORS origins for browser calls from Moodle
NEURO_API_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
